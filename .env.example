# AgroVision AI — Environment Configuration
# Copy this file to .env and fill in your values

# AI Provider: gemini | openai | openrouter
AI_PROVIDER=gemini
AI_API_KEY=your-api-key-here

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./agrovision.db
